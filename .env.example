# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Choose ONE of the following:

# Option 1: OpenAI (Recommended for production)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Option 3: Ollama (Free, runs locally)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# =============================================================================
# Data Source APIs
# =============================================================================

# NewsAPI (Get free key at: https://newsapi.org/)
NEWSAPI_KEY=your-newsapi-key-here

# Alpha Vantage (Get free key at: https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here

# Yahoo Finance (No key needed, but can set user agent)
YAHOO_FINANCE_USER_AGENT=Mozilla/5.0

# World Bank API (Optional, no key needed for basic access)
WORLD_BANK_API_URL=https://api.worldbank.org/v2

# =============================================================================
# Vector Database Configuration
# =============================================================================

# ChromaDB Settings
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=financial_news
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Application Settings
# =============================================================================

# General
APP_NAME=Financial News Analyzer
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=True

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True

# Streamlit Settings
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501

# =============================================================================
# Data Collection Settings
# =============================================================================

# News Collection
MAX_NEWS_ARTICLES=100
NEWS_SOURCES=bloomberg,reuters,cnbc,financial-times,wall-street-journal
NEWS_LANGUAGE=en
DEFAULT_LOOKBACK_DAYS=7

# Stock Data
DEFAULT_STOCK_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA
STOCK_DATA_INTERVAL=1d  # 1m, 5m, 15m, 30m, 1h, 1d, 1wk, 1mo

# Economic Indicators
ECONOMIC_INDICATORS=GDP,CPI,UNEMPLOYMENT,INTEREST_RATE

# =============================================================================
# Cache Configuration
# =============================================================================

CACHE_ENABLED=True
CACHE_TYPE=disk  # memory, disk, redis
CACHE_TTL=3600  # seconds (1 hour)
CACHE_DIR=./data/cache
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Agent Configuration
# =============================================================================

# Research Agent
RESEARCH_AGENT_MAX_ITERATIONS=5
RESEARCH_AGENT_TEMPERATURE=0.3

# Sentiment Agent
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
SENTIMENT_CONFIDENCE_THRESHOLD=0.75

# Risk Agent
RISK_ALERT_THRESHOLD=0.7
RISK_FACTORS=volatility,news_sentiment,volume,regulatory

# Summary Agent
SUMMARY_MAX_LENGTH=500
SUMMARY_STYLE=professional  # professional, casual, technical

# =============================================================================
# Rate Limiting
# =============================================================================

RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # seconds

# API-specific rate limits
NEWSAPI_RATE_LIMIT=100  # requests per day on free tier
ALPHA_VANTAGE_RATE_LIMIT=5  # requests per minute on free tier

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite (default)
DATABASE_URL=sqlite:///./data/financial_analyzer.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/financial_analyzer

# =============================================================================
# Security
# =============================================================================

SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Email Notifications (Optional)
# =============================================================================

SMTP_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_RECIPIENTS=user1@example.com,user2@example.com

# =============================================================================
# Monitoring & Analytics (Optional)
# =============================================================================

# Sentry
SENTRY_DSN=

# Google Analytics
GA_TRACKING_ID=

# =============================================================================
# Feature Flags
# =============================================================================

FEATURE_REAL_TIME_MONITORING=True
FEATURE_SENTIMENT_ANALYSIS=True
FEATURE_RISK_ALERTS=True
FEATURE_REPORT_GENERATION=True
FEATURE_PORTFOLIO_OPTIMIZATION=False
FEATURE_BACKTESTING=False

# =============================================================================
# Performance Tuning
# =============================================================================

MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30  # seconds
MAX_RETRIES=3
BATCH_SIZE=50

# Vector Search
VECTOR_SEARCH_K=10  # number of results
VECTOR_SEARCH_THRESHOLD=0.7  # similarity threshold

# =============================================================================
# Development Settings
# =============================================================================

MOCK_API_CALLS=False  # Use mock data instead of real API calls
SAMPLE_DATA_SIZE=100
TEST_MODE=False
