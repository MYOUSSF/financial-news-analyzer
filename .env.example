# =============================================================================
# Financial News Analyzer — Environment Variables
# Copy to .env and fill in your values. Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Providers (configure at least one)
# Priority order: OpenAI → Anthropic → Ollama
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# Data Sources
# -----------------------------------------------------------------------------
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
CHROMA_DB_PATH=./data/chroma_db
BACKTESTING_DB_PATH=data/backtesting.db

# -----------------------------------------------------------------------------
# Caching (Redis — optional, falls back to in-memory)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Alert Dispatch
# Set ALERT_WEBHOOK_URL to receive HIGH/CRITICAL alerts via HTTP POST.
# Set SMTP_* + ALERT_EMAIL_TO to also receive CRITICAL alerts by email.
# -----------------------------------------------------------------------------
ALERT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_PORT=8000
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
DASH_PORT=8501

# -----------------------------------------------------------------------------
# Logging
# DEBUG | INFO | WARNING | ERROR
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
